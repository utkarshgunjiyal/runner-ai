# ---------------------------------------------------------------------------
# Runner.ai — environment configuration
# Copy to `.env` and fill in values. Never commit the real `.env`.
#
# Running on the host (uvicorn/worker directly): the localhost URLs below are
# correct. Running via `docker compose`: Compose overrides the service
# hostnames (mongodb/redis/qdrant/minio) itself and only reads API keys +
# LLM_* / LOG_LEVEL from this file — so the localhost values here are ignored
# inside containers.
# ---------------------------------------------------------------------------

# -- Application -------------------------------------------------------------
APP_NAME=Runner.ai
APP_VERSION=1.5.0
ENVIRONMENT=development           # development | staging | production
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR

# -- MongoDB (required) ------------------------------------------------------
MONGO_URL=mongodb://localhost:27017
DB_NAME=runner_ai_v1

# -- CORS --------------------------------------------------------------------
# Comma-separated origins, or "*" for all (credentials are disabled with "*").
# REQUIRED for production: set explicit origins (never "*") so cookies work.
# Example: CORS_ORIGINS=http://localhost:3000,https://app.runner.ai
CORS_ORIGINS=*

# ---------------------------------------------------------------------------
# Operational hardening (Phase 42A). All optional with safe defaults.
# ---------------------------------------------------------------------------

# -- Agent runtime backends --------------------------------------------------
AGENT_CHECKPOINT_BACKEND=memory   # memory | mongo (mongo = durable resume)
AGENT_USE_REAL_LLM=false          # true = use the real LLM providers
AGENT_MCP_ENABLED=false           # true = mount trusted MCP servers (composition)

# -- Request correlation + body limits --------------------------------------
CORRELATION_ID_HEADER=X-Request-ID
MAX_REQUEST_BODY_BYTES=33554432   # 32 MB safety ceiling (> MAX_UPLOAD_BYTES)

# -- Security headers --------------------------------------------------------
SECURITY_HEADERS_ENABLED=true
# CONTENT_SECURITY_POLICY="default-src 'none'; frame-ancestors 'none'"

# -- Metrics -----------------------------------------------------------------
METRICS_ENABLED=false             # true = expose GET /metrics
METRICS_BACKEND=memory            # memory | prometheus (needs prometheus_client)

# -- Rate limiting -----------------------------------------------------------
RATE_LIMIT_ENABLED=false          # true in production
RATE_LIMIT_BACKEND=memory         # memory (single-process) | redis (multi-process)
RATE_LIMIT_RUN_PER_MINUTE=30
RATE_LIMIT_STREAM_PER_MINUTE=10
RATE_LIMIT_RESUME_PER_MINUTE=60

# -- SSE keep-alive ----------------------------------------------------------
SSE_HEARTBEAT_SECONDS=15          # 0 disables idle heartbeats

# -- Logging -----------------------------------------------------------------
LOG_SENSITIVE=false               # keep OFF; opt-in local debugging only

# ---------------------------------------------------------------------------
# Deployment & demo (Phase 42B). Single-VM production via Caddy reverse proxy.
# ---------------------------------------------------------------------------

# -- Public edge (Caddy) -----------------------------------------------------
DOMAIN=demo.example.com           # public hostname; Caddy gets HTTPS for it
TLS_EMAIL=you@example.com         # ACME/Let's Encrypt account email
# BACKEND_UPSTREAM=backend:8000   # internal upstreams (defaults shown)
# FRONTEND_UPSTREAM=frontend:80

# -- Production auth gate -----------------------------------------------------
# The API ships a DEVELOPMENT auth stub (everyone = dev_user). In production the
# backend REFUSES to boot while the stub is active unless this is explicitly
# true (a private demo behind Caddy basic auth). Replace with real auth for
# public multi-user use. See docs/SECURITY.md.
ALLOW_DEV_AUTH=false
COOKIE_SECURE=true                # TLS-only cookies (set true in production)
COOKIE_SAMESITE=lax               # lax | strict | none (none requires secure)

# -- Demo mode ----------------------------------------------------------------
# OFF by default and REFUSED in production. Enable only for a private, demo-
# profile deployment (ENVIRONMENT=demo). Marked prompts then pause for HITL
# (approval/clarification) through the real checkpoint/resume path.
DEMO_MODE=false

# -- Object storage credentials (docker compose reads these) -----------------
# MINIO_ROOT_USER=minioadmin      # CHANGE for production
# MINIO_ROOT_PASSWORD=minioadmin  # CHANGE for production

# ---------------------------------------------------------------------------
# Infrastructure & pipeline (defaults match docker-compose.yml)
# ---------------------------------------------------------------------------

# -- Redis (job queue) -------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
JOB_QUEUE_NAME=runner:jobs:document_ingest
WORKER_DEQUEUE_TIMEOUT=5

# -- Qdrant (vector store) ---------------------------------------------------
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
QDRANT_COLLECTION=document_chunks

# -- MinIO / S3 (object storage for uploads) ---------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=runner-uploads
MINIO_SECURE=false

# -- Embeddings (deterministic stub provider) --------------------------------
EMBEDDING_DIM=384

# -- LLM ---------------------------------------------------------------------
# provider: auto | anthropic | openrouter | stub
#   auto  -> anthropic if ANTHROPIC_API_KEY set, else openrouter if
#            OPENROUTER_API_KEY set, else stub (no network; echoes prompt)
LLM_PROVIDER=auto
LLM_MODEL=claude-sonnet-5          # for openrouter use e.g. anthropic/claude-3.5-sonnet
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.3
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# -- Document ingestion ------------------------------------------------------
MAX_UPLOAD_BYTES=26214400          # 25 MB
ALLOWED_CONTENT_TYPES=application/pdf
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
SUMMARY_MAX_CHARS=1500

# -- Context budget ----------------------------------------------------------
CONTEXT_CHARS_PER_TOKEN=4

# -- GitHub read-only MCP connector (Phase 46.2) -----------------------------
# Deployment-scoped GitHub integration through the official GitHub MCP server.
# DISABLED unless GITHUB_MCP_ENABLED=true AND a token is set. The token is a
# SECRET — provide it via the environment only (never commit a real value).
# Use a LOW-PRIVILEGE, read-only token (public_repo / repo:read). NOTE: this is
# deployment-scoped, not per-user OAuth — every user of a deployment with this
# enabled shares the configured account, so restrict deployment access.
GITHUB_MCP_ENABLED=false
# Provide ONE of these (placeholder names only — no real token here):
# GITHUB_MCP_TOKEN=
# GITHUB_PERSONAL_ACCESS_TOKEN=
# Pin the server image to a stable release you have verified (never :latest):
GITHUB_MCP_IMAGE=ghcr.io/github/github-mcp-server:v0.6.0
GITHUB_MCP_TOOLSETS=repos,issues,pull_requests
GITHUB_MCP_TIMEOUT_SECONDS=45
