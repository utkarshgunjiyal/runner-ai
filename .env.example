# ---------------------------------------------------------------------------
# Runner.ai — environment configuration
# Copy to `.env` and fill in values. Never commit the real `.env`.
# ---------------------------------------------------------------------------

# -- Application -------------------------------------------------------------
APP_NAME=Runner.ai
APP_VERSION=1.5.0
ENVIRONMENT=development           # development | staging | production
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR

# -- MongoDB (required) ------------------------------------------------------
MONGO_URL=mongodb://localhost:27017
DB_NAME=runner_ai_v1

# -- CORS --------------------------------------------------------------------
# Comma-separated origins, or "*" for all (credentials are disabled with "*").
# Example: CORS_ORIGINS=http://localhost:3000,https://app.runner.ai
CORS_ORIGINS=*

# ---------------------------------------------------------------------------
# Reserved for later phases (safely ignored until wired up).
# ---------------------------------------------------------------------------

# -- Redis (Phase 1 — job queue) ---------------------------------------------
# REDIS_URL=redis://localhost:6379/0

# -- Qdrant (Phase 1/2 — vector store) ---------------------------------------
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# -- MinIO / S3 (Phase 1 — object storage for uploads) -----------------------
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=runner-uploads
# MINIO_SECURE=false

# -- LLM / Embeddings (Phase 2/3) --------------------------------------------
# LLM_PROVIDER=anthropic          # anthropic | openrouter
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# LLM_MODEL=claude-sonnet-5
# EMBEDDING_MODEL=
