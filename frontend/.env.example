# Runner.ai frontend — environment (Vite). Copy to `.env` for local dev.
#
# Vite only exposes variables prefixed with VITE_ to the client, and they are
# baked in at BUILD time (not runtime). Never put secrets here — anything here
# ships to the browser.

# Backend base URL used by the SPA's API client.
#   ""  (empty, default) -> same-origin: the dev server proxies /agent to the
#        backend, and the production nginx image proxies /agent to BACKEND_URL.
#        Keep it empty so auth cookies stay same-origin.
#   Set a full URL only for a genuinely cross-origin backend (then the backend
#   CORS_ORIGINS must include this app's origin, and cookies must be SameSite=None).
VITE_BACKEND_URL=

# Dev-server proxy target (used by vite.config.ts in `npm run dev` only).
# The production image ignores this and uses the nginx BACKEND_URL env instead.
# VITE_BACKEND_URL above stays empty; this controls where the dev proxy forwards.
# (Set on the host shell, e.g. VITE_BACKEND_URL=http://localhost:8000 npm run dev,
#  is unnecessary — the proxy defaults to http://localhost:8000.)
